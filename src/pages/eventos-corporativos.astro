---
// Gerado a partir de: eventos-corporativos.html
// Carmel Eventos - Página de Eventos Corporativos
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import '../styles/eventos-corporativos.css';
---

<Base
  title="Eventos Corporativos | Carmel Eventos"
  description="Um espaço cercado pela natureza, com estrutura completa para convenções, treinamentos e confraternizações corporativas."
  canonical="https://carmeleventos.com.br/eventos-corporativos/"
>
  <Fragment slot="head">
    <!-- Fontes do Google -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Gilda+Display&family=Poppins:wght@400;500;600;700&family=Raleway:wght@300;400;500;600&family=Roboto+Slab:wght@300;400;500;600&family=Roboto:wght@300;400;500;600&family=Sora:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <!-- Flatpickr (Calendário) CDN -->
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/flatpickr.min.css">
    <script src="https://npmcdn.com/flatpickr/dist/flatpickr.min.js" defer></script>
  </Fragment>

  <main class="carmel-eventos-page">
    
    <!-- 1. HERO SECTION -->
    <section class="hero-section">
      <div class="hero-logo-wrapper">
        <Img src="carmel-logo-1.avif" alt="Carmel Eventos Logo" priority />
      </div>
      <h1 class="hero-title">Onde decisões estratégicas encontram o ritmo do campo</h1>
      <p class="hero-subtitle">Um espaço cercado pela natureza, com estrutura completa para empresas que desejam transformar encontros corporativos em experiências memoráveis.</p>
      <div class="hero-btn-wrapper">
        <a class="btn hero-btn" href="#contato">Solicite um orçamento</a>
      </div>
    </section>

    <!-- 2. REFÚGIO SECTION -->
    <section class="refugio-section pattern-gold-bg">
      <h2 class="section-title">Um refúgio corporativo pensado para conexões mais humanas</h2>
      <div class="refugio-desc section-desc">
        <p>Localizado em Indaiatuba, a cerca de 1h30 de São Paulo, ao lado do Parque Mirim, o Carmel Campo oferece o equilíbrio ideal entre tranquilidade, sofisticação e estrutura para eventos corporativos no campo.</p>
        <p>Projetado para receber encontros empresariais de médio e grande porte, o espaço proporciona uma experiência que vai além do formato tradicional: <strong>convenções, treinamentos, confraternizações, imersões, lançamentos e encontros estratégicos</strong> ganham um novo cenário, integrado ao verde e preparado para estimular troca, criatividade e conexão.</p>
        <p>Com salão envidraçado, ambientes versáteis e áreas externas integradas à natureza, o Carmel Campo cria o ambiente ideal para empresas que desejam unir conforto, produtividade e experiências marcantes em um só lugar.</p>
      </div>
    </section>

    <!-- 3. FACHADA IMAGE DIVIDER -->
    <div class="fachada-divider"></div>

    <!-- 4. ESTRUTURA SECTION -->
    <section class="estrutura-section pattern-gold-bg">
      <h2 class="section-title">Estrutura versátil para eventos que pedem mais do que um auditório</h2>
      <div class="gallery-grid">
        <div class="gallery-item">
          <Img src="galeria.ets-corporativo04_resultado.avif" alt="Área externa com lago e áreas verdes no Carmel Campo" />
          <div class="gallery-overlay"></div>
        </div>
        <div class="gallery-item">
          <Img src="galeria.ets-corporativo01_resultado.avif" alt="Ambiente interno montado para evento corporativo" />
          <div class="gallery-overlay"></div>
        </div>
        <div class="gallery-item">
          <Img src="galeria.ets-corporativo02_resultado.avif" alt="Vista do salão envidraçado do Carmel Campo" />
          <div class="gallery-overlay"></div>
        </div>
        <div class="gallery-item">
          <Img src="galeria.ets-corporativo03_resultado.avif" alt="Integração de ambientes e vista para a natureza" />
          <div class="gallery-overlay"></div>
        </div>
      </div>
    </section>

    <!-- 5. NATUREZA & ESTRUTURA FEATURES -->
    <section class="natureza-section pattern-dark-bg">
      <h2 class="section-title">Natureza, conforto e infraestrutura alinhados ao ritmo do seu evento</h2>
      <p class="section-desc">Um espaço preparado para receber eventos corporativos com fluidez, sofisticação e suporte completo, combinando ambientes integrados, áreas externas e estrutura funcional para experiências mais produtivas e memoráveis.</p>
      
      <div class="features-grid">
        
        <!-- Feature 1: Capacidade -->
        <div class="feature-box">
          <div class="feature-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <span class="feature-title">Capacidade para até<br>200 convidados</span>
        </div>

        <!-- Feature 2: Vista Verde -->
        <div class="feature-box">
          <div class="feature-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l3.5 7H8.5L12 2zM12 9l4.5 9H7.5L12 9zM12 18v4"></path>
            </svg>
          </div>
          <span class="feature-title">Salão envidraçado com vista<br>para o verde</span>
        </div>

        <!-- Feature 3: Área Externa -->
        <div class="feature-box">
          <div class="feature-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 12l2.5 5H3.5L6 12z" />
              <path d="M6 17v3" />
              <path d="M12 5l4 8H8l4-8z" />
              <path d="M12 13v7" />
              <path d="M18 9l3 6h-6l3-6z" />
              <path d="M18 15v5" />
            </svg>
          </div>
          <span class="feature-title">Área externa integrada<br>à natureza</span>
        </div>

        <!-- Feature 4: Versatilidade -->
        <div class="feature-box">
          <div class="feature-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 3 21 3 21 9" />
              <polyline points="9 21 3 21 3 15" />
              <line x1="21" y1="3" x2="14" y2="10" />
              <line x1="3" y1="21" x2="10" y2="14" />
              <polyline points="9 3 3 3 3 9" />
              <polyline points="15 21 21 21 21 15" />
              <line x1="3" y1="3" x2="10" y2="10" />
              <line x1="21" y1="21" x2="14" y2="14" />
            </svg>
          </div>
          <span class="feature-title">Ambientes versáteis para<br>diferentes formatos</span>
        </div>

        <!-- Feature 5: Espaços de Apoio -->
        <div class="feature-box">
          <div class="feature-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <line x1="20" y1="8" x2="20" y2="14"></line>
              <line x1="23" y1="11" x2="17" y2="11"></line>
            </svg>
          </div>
          <span class="feature-title">Espaços de apoio para<br>equipes e fornecedores</span>
        </div>

        <!-- Feature 6: Estacionamento -->
        <div class="feature-box">
          <div class="feature-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m19 10-1.5-5.5a1 1 0 0 0-1-.5h-9a1 1 0 0 0-1 .5L5 10" />
              <path d="M4 17h16" />
              <rect x="3" y="10" width="18" height="7" rx="2" />
              <circle cx="7" cy="13.5" r="1" />
              <circle cx="17" cy="13.5" r="1" />
              <path d="M5 20v-3" />
              <path d="M19 20v-3" />
            </svg>
          </div>
          <span class="feature-title">Estacionamento<br>amplo</span>
        </div>

        <!-- Feature 7: Cozinha de suporte -->
        <div class="feature-box">
          <div class="feature-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2M7 2v20M21 15V2v0a5 5 0 0 0-5 5v8c0 1.1.9 2 2 2h1a2 2 0 0 0 2-2zM19 17v5"/>
            </svg>
          </div>
          <span class="feature-title">Cozinha de suporte<br>com churrasqueira</span>
        </div>

        <!-- Feature 8: Gerador -->
        <div class="feature-box">
          <div class="feature-icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <span class="feature-title">Gerador<br>próprio</span>
        </div>

      </div>
    </section>

    <!-- 6. DETALHES CARROSSEL SECTION -->
    <section class="detalhes-section pattern-gold-bg">
      <h2 class="section-title">Um espaço onde cada detalhe valoriza a experiência corporativa</h2>
      
      <div class="carousel-outer-wrapper">
        <div class="carousel-container">
          
          <!-- Prev Button -->
          <button class="carousel-btn carousel-btn-prev" aria-label="Slide anterior">
            <svg viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg">
              <path d="M646 125C629 125 613 133 604 142L308 442C296 454 292 471 292 487 292 504 296 521 308 533L604 854C617 867 629 875 646 875 663 875 679 871 692 858 704 846 713 829 713 812 713 796 708 779 692 767L438 487 692 225C700 217 708 204 708 187 708 171 704 154 692 142 675 129 663 125 646 125Z"/>
            </svg>
          </button>

          <!-- Slides Viewport -->
          <div class="carousel-viewport">
            <div class="carousel-slide">
              <Img src="carrossel-corporativo07_resultado.avif" alt="Detalhe do evento corporativo no Carmel" />
            </div>
            <div class="carousel-slide">
              <Img src="carrossel-corporativo06_resultado.avif" alt="Área verde externa" />
            </div>
            <div class="carousel-slide">
              <Img src="carrossel-corporativo04_resultado.avif" alt="Salão principal pronto para palestra" />
            </div>
            <div class="carousel-slide">
              <Img src="carrossel-corporativo05_resultado.avif" alt="Layout interno de mesas e cadeiras" />
            </div>
            <div class="carousel-slide">
              <Img src="carrossel-corporativo03_resultado.avif" alt="Visão panorâmica externa" />
            </div>
            <div class="carousel-slide">
              <Img src="carrossel-corporativo02_resultado.avif" alt="Pátio externo e natureza ao redor" />
            </div>
            <div class="carousel-slide">
              <Img src="carrossel-corporativo01_resultado.avif" alt="Recepção principal do Carmel Campo" />
            </div>
          </div>

          <!-- Next Button -->
          <button class="carousel-btn carousel-btn-next" aria-label="Próximo slide">
            <svg viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg">
              <path d="M696 533C708 521 713 504 713 487 713 471 708 454 696 446L400 146C388 133 375 125 354 125 338 125 325 129 313 142 300 154 292 171 292 187 292 204 296 221 308 233L563 492 304 771C292 783 288 800 288 817 288 833 296 850 308 863 321 871 338 875 354 875 371 875 388 867 400 854L696 533Z"/>
            </svg>
          </button>

        </div>
      </div>
    </section>

    <!-- 7. CONTATO (FORMULÁRIO) SECTION -->
    <section class="contato-section" id="contato">
      <h2 class="section-title">Seu próximo evento pode acontecer longe do óbvio</h2>
      
      <div class="form-card-wrapper">
        <p class="form-card-subtitle">Preencha seus dados e receba um orçamento personalizado.</p>
        <LeadForm
          formId="contato-corporativo"
          project={config.project_slug}
          submitUrl={config.forms['lead-form'].webhooks[0]}
          redirectUrl={config.forms['lead-form'].redirect_on_success}
          submitText="ENVIAR SOLICITAÇÃO"
          honeypot
          fields={[
            { name: 'form_fields[nome]', type: 'text', label: 'Nome', required: true },
            {
              type: 'row',
              fields: [
                { name: 'form_fields[telefone]', type: 'text', label: 'WhatsApp', required: true },
                { name: 'form_fields[email]', type: 'email', label: 'E-mail', required: true }
              ]
            },
            { name: 'form_fields[tipo]', type: 'select', label: 'Tipo de Evento', required: true, options: [
              { value: '', label: '' },
              { value: 'Confraternização corporativa', label: 'Confraternização corporativa' },
              { value: 'Corporativo', label: 'Corporativo' },
              { value: 'Feiras e Exposições', label: 'Feiras e Exposições' },
              { value: 'Happy Hours', label: 'Happy Hours' },
              { value: 'Masterclass e Palestras', label: 'Masterclass e Palestras' },
              { value: 'Mentorias e Treinamentos', label: 'Mentorias e Treinamentos' },
              { value: 'Offsite corporativo', label: 'Offsite corporativo' },
              { value: 'Reuniões de Networking', label: 'Reuniões de Networking' },
              { value: 'Shows e Festivais', label: 'Shows e Festivais' },
              { value: 'Workshops, Conferências e Seminários', label: 'Workshops, Conferências e Seminários' },
              { value: 'Outros', label: 'Outros' }
            ] },
            { name: 'form_fields[data]', type: 'text', label: 'Data do Evento', required: true, readonly: true },
            { name: 'form_fields[convidados]', type: 'number', label: 'Nº de Pessoas', required: true },
            { name: 'form_fields[mensagem]', type: 'textarea', label: 'Detalhes adicionais: (Não obrigatório)', required: false }
          ]}
        />
      </div>
    </section>

    <!-- 8. MAPA / LOCALIZAÇÃO SECTION -->
    <section class="mapa-section pattern-dark-bg">
      <h2 class="section-title">Um cenário no campo com fácil acesso para empresas de São Paulo e região</h2>
      
      <div class="mapa-image-container">
        <Img src="Screenshot-2025-12-09-at-19.16.34.avif" alt="Mapa de localização do Carmel Campo em Indaiatuba" width={1920} quality={100} />
      </div>
    </section>

    <!-- 9. FOOTER SECTION -->
    <footer class="footer-section">
      <div class="footer-container">
        <div class="footer-copyright">
          <p>© 2026 - Carmel Campo - Todos os direitos reservados</p>
        </div>
        <div class="footer-logo">
          <Img src="carmel-logo-1.avif" alt="Carmel Eventos Logo" />
        </div>
        <div class="footer-dmove">
          <span>Desenvolvido por</span>
          <a class="footer-dmove-logo" href="https://dmove.com.br" target="_blank" rel="noopener noreferrer">
            <Img src="Versao-Principal-Negativo-scaled-e1750426923582.avif" alt="Dmove Logo" />
          </a>
        </div>
      </div>
    </footer>

  </main>

  <script>
    import '../scripts/eventos-corporativos.js';
  </script>
</Base>
